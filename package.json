{
  "name": "memoria",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "tsc --noEmit",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "npm run lint && npm run test:rust",
    "test:unit:ui": "vitest run src/lib/responsiveGrid.test.ts",
    "test:ui": "playwright test",
    "test:ui:browser": "playwright test --project=browser-chromium",
    "test:ui:desktop": "playwright test --project=desktop-windows",
    "test:ui:headed": "playwright test --headed"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.67.1",
    "@tanstack/react-virtual": "^3.13.22",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "framer-motion": "^12.36.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.0"
  }
}
