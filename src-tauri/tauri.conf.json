{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memoria",
  "version": "0.1.0",
  "identifier": "com.memoria.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Memoria",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["msi"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "resources": [
      "../vendor/exiftool.exe",
      "../vendor/ffmpeg.exe"
    ]
  }
}
